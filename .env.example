AIGENT_VERSION=0.3.0-oss
AIGENT_TENANT_ID=default
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=alibayram/smollm3
EMBEDDING_BASE_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CONTEXT_WINDOW=65536
# Max tokens for dialogue responses. Routing calls use min(192, this value).
OLLAMA_MAX_RESPONSE_TOKENS=1024
AIGENT_AGENT_ID=basic-assistant
CHAT_DB_PATH=/app/models-local/chat.db
WORKER_POLL_INTERVAL_MS=750
MEMORY_CHUNK_LIMIT=160
MEMORY_COMPACTION_BATCH_SIZE=24
MCP_TIMEOUT_SECONDS=15
MARKITDOWN_MCP_ENABLED=true
MARKITDOWN_MCP_URL=http://markitdown-mcp:3001/mcp/
MARKITDOWN_MCP_UPLOADS_DIR=/data/uploads
MARKITDOWN_MCP_TOOL_NAME=convert_to_markdown

HOST_PORT_WEBUI=5500
HOST_PORT_KERNEL=5501
# HOST_PORT_OLLAMA=5504
